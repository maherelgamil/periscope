{
    "name": "maherelgamil/periscope",
    "description": "A universal queue monitor for Laravel — see into any queue driver (Redis, database, SQS, Beanstalkd).",
    "keywords": [
        "laravel",
        "queue",
        "monitor",
        "horizon",
        "redis",
        "sqs",
        "beanstalkd",
        "dashboard"
    ],
    "license": "MIT",
    "type": "library",
    "homepage": "https://github.com/maherelgamil/periscope",
    "support": {
        "issues": "https://github.com/maherelgamil/periscope/issues",
        "source": "https://github.com/maherelgamil/periscope"
    },
    "authors": [
        {
            "name": "Maher ElGamil",
            "email": "maherelgamil@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/queue": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "livewire/livewire": "^4.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "MaherElGamil\\Periscope\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MaherElGamil\\Periscope\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "MaherElGamil\\Periscope\\PeriscopeServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
